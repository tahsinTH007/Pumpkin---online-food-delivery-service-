{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",

    // For nodejs:
    "lib": ["ES2020"],
    "types": ["node"],

    // Other Outputs
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    // Module compatibility and imports
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // Type safety enhancements
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "skipLibCheck": true
  }
}
